# MoneyMind Backend Configuration

# Server Configuration
PORT=8085
GIN_MODE=release
ENVIRONMENT=production

# Database Configuration
DATABASE_URL=postgresql://postgres:moneymind123@localhost:5432/moneymind?sslmode=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-moneymind-2025
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=720h

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10MB

# CORS Configuration
ALLOWED_ORIGINS=http://173.212.217.52:5174,http://localhost:5174,http://localhost:3000,http://103.61.235.202:5174
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,Accept,X-Requested-With,Access-Control-Request-Method,Access-Control-Request-Headers

# Email Configuration (for password reset, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@moneymind.com
FROM_NAME=MoneyMind

# Security
BCRYPT_COST=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=1h

# Logging
LOG_LEVEL=info
LOG_FORMAT=json